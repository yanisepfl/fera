# FERA frontend env (copy to .env.local). Every value is optional in mock mode.

# --- Data source -------------------------------------------------------------
# When unset, lib/api.ts serves from mocks/fixtures.ts (zero network, works in CI/build).
# Set to Backend (4)'s indexer/API base to go live. Contract shapes: MASTER_SPEC §8.
NEXT_PUBLIC_API_URL=

# Force the MSW browser worker (realistic network + latency) even with NEXT_PUBLIC_API_URL unset.
# "1" = intercept /api/* with mocks/handlers.ts. Requires `npm run mocks:init` once.
NEXT_PUBLIC_USE_MSW=0

# --- Wallets -----------------------------------------------------------------
# WalletConnect Cloud projectId. Injected + Robinhood-Wallet deep-link work without it;
# the WalletConnect connector is a no-op until this is set.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Chain (Robinhood Chain — Arbitrum Orbit L2). Confirm in docs/CHAIN.md before mainnet.
NEXT_PUBLIC_CHAIN_ID=
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_EXPLORER_URL=
