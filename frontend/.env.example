# FERA frontend env (copy to .env.local for local dev; set the same keys in Vercel).
# Every value is OPTIONAL in mock mode: with nothing set the app builds, renders, and
# serves fixtures with zero network, and injected wallets (MetaMask/Rabby/Robinhood
# in-app browser) still connect. The keys below unlock live data + full wallet support.

# --- Data source -------------------------------------------------------------
# When unset, lib/api.ts serves from mocks/fixtures.ts (zero network, works in CI/build).
# Set to Backend (4)'s indexer/API base to go live. Contract shapes: MASTER_SPEC §8.
NEXT_PUBLIC_API_URL=

# Force the MSW browser worker (realistic network + latency) even with NEXT_PUBLIC_API_URL unset.
# "1" = intercept /api/* with mocks/handlers.ts. Requires `npm run mocks:init` once.
NEXT_PUBLIC_USE_MSW=0

# --- Wallet (RainbowKit + WalletConnect) -------------------------------------
# WalletConnect Cloud / Reown projectId (https://cloud.reown.com). REQUIRED for mobile
# wallets + the WalletConnect QR flow. Injected wallets work without it. Until it is set,
# the config falls back to a placeholder so `next build`/SSR never throw; the WC client
# is only created on connect, so mobile connect simply won't pair until a real id is set.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Chain (Robinhood Chain - Arbitrum Orbit L2). Verified in docs/CHAIN.md §0/§1.
# Defaults below are the VERIFIED mainnet identity; override only to repoint the RPC
# (e.g. an Alchemy/QuickNode endpoint - the public RPC is rate-limited) or to run against
# testnet. Set NEXT_PUBLIC_CHAIN_ID=46630 to make the Robinhood testnet the active network.
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_EXPLORER_URL=https://robinhoodchain.blockscout.com

# Testnet (chain id 46630) is always registered in the wallet; override its RPC/explorer here.
NEXT_PUBLIC_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://explorer.testnet.chain.robinhood.com

# =============================================================================
# DEPLOYING TO VERCEL
# -----------------------------------------------------------------------------
# 1. Project → Settings → Root Directory = "frontend" (this is a monorepo; the Next.js
#    app is not at the repo root). Framework preset auto-detects as Next.js.
# 2. Build command "next build" / output ".next" are the defaults - leave them.
# 3. Add the env vars above under Settings → Environment Variables. The only one you MUST
#    set for a real deploy is NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID (get it free at
#    cloud.reown.com; register your Vercel domain in its Allowed Domains). Everything else
#    has a working default. Set NEXT_PUBLIC_API_URL once Backend's indexer is live.
# 4. Note: NEXT_PUBLIC_* vars are inlined at BUILD time - redeploy after changing them.
# =============================================================================
