# FERA backend env (copy to .env for local dev). Every value below is OPTIONAL — the
# pre-deployment dev API (`npm run api:dev`) boots with working defaults and no secrets.
# NOTE: never commit a real .env — the repo is public. Keeper/indexer signing keys and
# private RPC URLs belong only in an untracked .env (see keepers/ and ponder.config.ts).

# --- Dev API server (api/devServer.ts) ---------------------------------------
# Port the pre-deployment live-market + ToS API listens on.
PORT=42070

# CORS allow-list: comma-separated origins that browsers may call this API from.
# Anything else is refused (no Access-Control-Allow-Origin echoed). Default is the local
# frontend; set your deployed origin(s) for production, e.g. https://app.fera.fi,https://fera.fi
FERA_ALLOWED_ORIGINS=http://localhost:3000

# Per-IP rate limit (token bucket): burst size + sustained refill/sec. Defaults comfortably
# clear a normal browser session while making the endpoint hard to hammer / quota-drain.
FERA_RATE_BURST=120
FERA_RATE_REFILL_PER_SEC=8
# Set to 1 ONLY behind a trusted reverse proxy that sets X-Forwarded-For (else the header
# is spoofable and must not be trusted for rate-limit keying). Default: key on socket peer.
FERA_TRUST_PROXY=0

# --- Terms-of-Service acceptance ledger (api/tosStore.ts) --------------------
# Backing store: auto (prefer node:sqlite when available, else JSONL) | sqlite | jsonl.
FERA_TOS_STORE=auto
# Storage paths (default under backend/.data/, which is gitignored). Point these at a
# durable/backed-up volume in production, or swap createTosStore() for a real DB.
FERA_TOS_DB_PATH=.data/tos.sqlite
FERA_TOS_LEDGER_PATH=.data/tos-acceptances.jsonl

# --- Live market data (api/marketData.ts, GeckoTerminal) ----------------------
# GeckoTerminal v2 base + the network id whose pools are served. NETWORK is charset-validated.
FERA_GT_BASE=https://api.geckoterminal.com/api/v2
FERA_MARKET_NETWORK=robinhood
FERA_MARKET_TOP_N=10
FERA_MARKET_TTL_MS=60000
FERA_MARKET_OHLCV_TTL_MS=120000
# Symbols classified as RWA (tokenized equities) rather than MEME (classification only).
FERA_RWA_SYMBOLS=AAPL,NVDA,TSLA,GOOG,GOOGL,MSFT,AMZN,META,HOOD,SPY,QQQ,COIN,MSTR

# --- Live indexer + indexed API (ponder.config.ts, api/index.ts) --------------
# Robinhood Chain MAINNET (chain id 4663, Arbitrum Orbit L2, ~100ms blocks).
# The public RPC below is rate-limited; swap in a paid Alchemy URL for production —
# PONDER_RPC_URL_RH is the only var to change.
PONDER_RPC_URL_RH=https://rpc.mainnet.chain.robinhood.com
PONDER_CHAIN_ID=4663
# Conservative polling for the rate-limited public RPC; 200-500ms on a paid RPC.
PONDER_POLL_MS=1000

# FERA deployment (2026-07-17, deploy txs at blocks 12347596-12347599 — public addresses).
FERA_START_BLOCK=12347590
FERA_VAULT_ADDRESS=0xa8cF82797ecBC8C5cD5F83D60e189dbDc88D959a
FERA_HOOK_ADDRESS=0x96CE193F25db9b75743332bB7C94e545f1a225C3
FERA_TOKEN_ADDRESS=0x820b266811C00Ac02F7B237119D72747ccd6aA99
FERA_ESFERA_ADDRESS=0x500fc24CB19307a0B9e44FfB170073aF8092e53D
FERA_EMISSIONS_ADDRESS=0xAe6F9a7cf20f88c0953EFcE650b4abF2182120e0
FERA_DISTRIBUTOR_ADDRESS=0xFC6424f125108C666E761A974006BCB73107E548
FERA_STAKING_ADDRESS=0x0B042cB2a4C47792BE0Dde59Ad2FcBE934324bA1
FERA_REVENUE_ADDRESS=0x36c4B21cc1333389E097e713c5F535edD5CB157f

# Epoch clock — read from EmissionsController: genesisTs()=1784314203, weekly epochs.
FERA_EMISSIONS_GENESIS_TS=1784314203
FERA_EPOCH_SECONDS=604800

# Competitor benchmarking — leave unset to disable. The v4 PoolManager singleton is
# 0x8366a39cc670b4001a1121b8f6a443a643e40951 (log-heavy on the public RPC; enable only with
# a paid RPC + COMPETITOR_POOL_META entries).
#RH_V4_POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951
#RH_V3_COMPETITOR_POOLS=
#RH_COMPETITOR_START_BLOCK=12653000
#COMPETITOR_POOL_META=

# Pool token metadata fallback (poolId -> tokens/decimals/symbols) + per-token meta +
# display-only USD price registry (E6). See backend/.env for the live 5-pool values
# (wWETH quote 0x0bd7d308f8e1639fab988df18a8011f41eacad73, USDG 6dp
# 0x5fc5360d0400a0fd4f2af552add042d716f1d168; memecoins unpriced -> $0 display value).
#FERA_POOL_TOKENS={"0x<poolId>":{"token0":"0x..","token1":"0x..","token0Decimals":18,"token1Decimals":18,"token0Symbol":"wWETH","token1Symbol":"TENDIES"}}
#FERA_TOKEN_META={"0x<token>":{"decimals":18,"symbol":"wWETH"}}
#FERA_PRICE_REGISTRY_E6={"0x<token>":"1842610000"}
FERA_LIVE_FEE_TTL_MS=1000
