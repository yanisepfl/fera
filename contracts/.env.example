# FERA — deployment environment. Copy to `.env` and fill your own values.
#   cp .env.example .env      (`.env` is gitignored — NEVER commit it)
# The Deploy.s.sol script + `forge` read these. Nothing here is a secret
# EXCEPT PRIVATE_KEY — keep that in .env only.

# ── Robinhood Chain — MAINNET (chain 4663) ─────────────────────────────
# Public RPC is rate-limited; use your own Alchemy key for real deploys.
RPC_URL=https://rpc.mainnet.chain.robinhood.com
# RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=4663
EXPLORER_URL=https://robinhoodchain.blockscout.com

# ── TESTNET (chain 46630) — use this FIRST for the routing probe (F) ────
# RPC_URL=https://rpc.testnet.chain.robinhood.com
# CHAIN_ID=46630
# EXPLORER_URL=https://explorer.testnet.chain.robinhood.com

# ── YOUR DEPLOYER KEY — SECRET, .env only, NEVER commit ────────────────
# Use a FRESH throwaway key funded with a little ETH — not your main wallet.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# ── Verified Uniswap v4 addresses on Robinhood Chain ───────────────────
# Source: Uniswap deployments (developers.uniswap.org/contracts/v4/deployments),
# verified on robinhoodchain.blockscout.com. Sanity-check on-chain before freezing.
POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951
POSITION_MANAGER=0x58daec3116aae6d93017baaea7749052e8a04fa7
UNIVERSAL_ROUTER=0x8876789976decbfcbbbe364623c63652db8c0904
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
V4_QUOTER=0x8dc178efb8111bb0973dd9d722ebeff267c98f94
STATE_VIEW=0xf3334192d15450cdd385c8b70e03f9a6bd9e673b

# ── Governance / roles — fill with YOUR addresses (Safe multisig ideal) ─
TREASURY_TIMELOCK_ADMIN=0xYOUR_TIMELOCK_OR_SAFE_ADDRESS
REWARD_TOKEN_ADMIN=0xYOUR_TIMELOCK_OR_SAFE_ADDRESS
KEEPER=0xYOUR_KEEPER_ADDRESS

# ── Chainlink feeds (RWA pools) ────────────────────────────────────────
# Read CURRENT proxy addresses from:
#   https://docs.chain.link/data-feeds/price-feeds/addresses?network=robinhood
# Contracts read decimals() on-chain, so only the proxy address is needed.
FEED_ETH_USD=0xFILL_FROM_CHAINLINK_DOCS
FEED_NVDA_USD=0xFILL_FROM_CHAINLINK_DOCS

# ── Token addresses on Robinhood Chain (fill from explorer at deploy) ──
WETH=0xFILL_FROM_EXPLORER
USDG=0xFILL_FROM_EXPLORER

# ── Blockscout verification (optional) ─────────────────────────────────
# BLOCKSCOUT_API_KEY=
