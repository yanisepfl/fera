# FERA — deployment env.  Copy to `.env` (GITIGNORED — never commit) and fill in your values:
#     cd contracts && cp .env.example .env && $EDITOR .env
# The deploy script reads every FERA_* var via vm.env*(). `source .env` before each command.

# ── Network (forge flags) — pick ONE. TESTNET (46630) first, then MAINNET (4663). ──────
RPC_URL=https://rpc.testnet.chain.robinhood.com
# RPC_URL=https://rpc.mainnet.chain.robinhood.com
# Best: your own Alchemy URL (public RPC is rate-limited):
# RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── DEPLOYER KEY — SECRET. Fresh throwaway EOA, funded with a little ETH. ──────────────
# EXACT name read by Deploy.s.sol (vm.envUint). Derive its address:
#   cast wallet address --private-key $FERA_DEPLOYER_PK
FERA_DEPLOYER_PK=0xYOUR_DEPLOYER_PRIVATE_KEY

# ── VERIFIED Uniswap v4 PoolManager on Robinhood Chain (4663) ─────────────────────────
FERA_POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951

# ── Roles. FAST SOLO LAUNCH: set ALL SIX to YOUR OWN address (no multisig — matches the
#    no-guardrails posture). PRODUCTION: use Gnosis Safe multisigs. ──────────────────────
# FERA_TIMELOCK_SAFE is "the team" — a general team/admin address, NOT a DAO. It owns
# EmissionsController/Vault and is rewardTokenAdmin (AnchorStaking) / the venue-allowlist,
# tier-config, and RWA-feed-registry approver in later stages. It is NOT the treasury (see
# FERA_TREASURY_EOA below) — Treasury.sol is no longer wired into this deploy at all (kept in
# the codebase, unused, for future optionality — contracts/OPEN_DECISIONS.md#OD-9).
FERA_TIMELOCK_SAFE=0xYOUR_ADDRESS          # "the team" — owns Emissions/Vault; is rewardTokenAdmin
FERA_EMISSIONS_KEEPER_SAFE=0xYOUR_ADDRESS  # posts emission caps
FERA_ROOT_POSTER_SAFE=0xYOUR_ADDRESS       # posts Merkle roots
FERA_VAULT_KEEPER=0xYOUR_ADDRESS           # runs RWA strategy + createPool
FERA_OPS_SINK=0xYOUR_ADDRESS               # 25% ops revenue recipient
# The treasury is a PLAIN EOA (freely spendable, no timelock friction) — the RevenueDistributor
# 25% recipient AND the sole beneficiary of GenesisVesting (the 10% genesis FERA allocation is
# LOCKED there under a 1yr-cliff/3yr-linear/4yr-total schedule, never sent here directly unlocked).
FERA_TREASURY_EOA=0xYOUR_ADDRESS           # treasury EOA (RevenueDistributor 25% + GenesisVesting beneficiary)

# ── Revenue / pair tokens on 4663 (read from robinhoodchain.blockscout.com) ────────────
FERA_WETH=0xFILL_FROM_EXPLORER
FERA_USDG=0xFILL_FROM_EXPLORER

# ── Chainlink feeds (RWA pools only) — proxy address; contracts read decimals() on-chain
#    https://docs.chain.link/data-feeds/price-feeds/addresses?network=robinhood
FEED_ETH_USD=0xFILL_FROM_CHAINLINK
FEED_NVDA_USD=0xFILL_FROM_CHAINLINK
