# ── Secrets: NEVER commit ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ── Node ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

